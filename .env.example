# ============================================================
# 大模型 API（默认：智谱 GLM，走 OpenAI 兼容协议）
# 从 https://open.bigmodel.cn/ 控制台获取 API Key
# ============================================================
OPENAI_API_KEY=请填入你的GLM_API_KEY
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ============================================================
# 模型选型（GLM）
# - LLM：glm-4-flash 免费、足够 demo；评测建议升 glm-4-air / glm-4-plus
# - Embedding：embedding-3（2048 维，中文友好）
# ============================================================
LLM_MODEL=glm-4-flash
EMBED_MODEL=embedding-3

# ============================================================
# 切换到 OpenAI 官方 / 其它 OpenAI 兼容服务商
# 只需改下面三项，代码无须改动
# ------------------------------------------------------------
# OpenAI 官方：
#   OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   EMBED_MODEL=text-embedding-3-small
#
# DeepSeek：
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#   （DeepSeek 暂无 embedding，仍需另配一个 embedding 服务）
# ============================================================

# ============================================================
# 检索 / 重试
# ============================================================
TOP_K=4
MAX_RETRIES=3

# ============================================================
# 本地存储
# ============================================================
CHROMA_DIR=./.chroma
DOCS_DIR=./data/sample_docs

# ============================================================
# 服务监听
# ============================================================
HOST=0.0.0.0
PORT=8000

# ============================================================
# 可选: LangSmith 链路追踪
# ============================================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__xxx
# LANGCHAIN_PROJECT=agentic-rag-demo
